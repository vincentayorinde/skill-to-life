# Dockerfile for an Nx pnpm Angular web app served by nginx
# Adjust APP_NAME and the output path for your workspace.
# Example Dockerfile path: apps/web/Dockerfile
# Healthcheck: set Nexloy's healthcheck path to / and container port to 8080.

FROM node:22-alpine AS build
WORKDIR /workspace
RUN corepack enable
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml nx.json ./
COPY apps ./apps
COPY libs ./libs
RUN pnpm install --frozen-lockfile
ARG APP_NAME=web
RUN pnpm nx run ${APP_NAME}:build:production

FROM nginxinc/nginx-unprivileged:1.27-alpine AS runtime
ARG APP_NAME=web
COPY --from=build /workspace/dist/apps/${APP_NAME}/browser /usr/share/nginx/html
EXPOSE 8080
CMD ["nginx", "-g", "daemon off;"]
