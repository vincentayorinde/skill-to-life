# Dockerfile for an Nx pnpm Angular web app served by nginx
# Healthcheck: set Nexloy's healthcheck path to / and container port to 8080.

FROM node:22-alpine AS build
WORKDIR /workspace
RUN corepack enable
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml nx.json tsconfig.base.json ./
COPY apps ./apps
COPY libs ./libs
RUN pnpm install --frozen-lockfile
ARG APP_NAME=web
ARG CACHEBUST=2025krun2
RUN pnpm nx run ${APP_NAME}:build:production --skip-nx-cache

FROM nginxinc/nginx-unprivileged:1.27-alpine AS runtime
ARG APP_NAME=web
COPY docker/nginx.web.conf /etc/nginx/conf.d/default.conf
COPY --from=build /workspace/dist/apps/${APP_NAME}/browser /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]